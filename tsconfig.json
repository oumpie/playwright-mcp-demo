{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "types": ["node", "@playwright/test"],
    "paths": {
      "@src/*":      ["src/*"],
      "@data/*":     ["src/data/*"],
      "@pages/*":    ["src/pages/*"],
      "@fixtures/*": ["src/fixtures/*"],
      "@utils/*":    ["src/utils/*"],
      "@config/*":   ["config/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "tests/**/*.ts",
    "config/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "reports",
    "test-results"
  ]
}
